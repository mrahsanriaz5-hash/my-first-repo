# ─────────────────────────────────────────────
#  InfraSpine Monitor – Environment Variables
# ─────────────────────────────────────────────

# Zabbix API base URL (no trailing slash)
ZABBIX_URL=http://your-zabbix-server/zabbix

# Zabbix credentials
ZABBIX_USERNAME=Admin
ZABBIX_PASSWORD=zabbix

# HTTP server port
PORT=5151

# MySQL connection (mysql2 driver)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=infraspine_monitor

